{
  "project": "fsdash",
  "service": {
    "renderServiceName": "fsdash-app"
  },
  "environments": {
    "local": {
      "description": "Developer machine pointing at local fs-ai backend"
    },
    "staging": {
      "description": "Render staging pointing at staging fs-ai backend"
    },
    "production": {
      "description": "Render production at fullstack.arkhamprison.com"
    }
  },
  "variables": {
    "PORT": {
      "kind": "config",
      "description": "HTTP port for the Express server",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "3000",
        "staging": "10000",
        "production": "10000"
      },
      "renderSync": true
    },
    "VITE_FULLSTACK_PUBLIC_BASE_URL": {
      "kind": "config",
      "description": "Public deployment URL for the FullStack dashboard",
      "requiredIn": ["staging", "production"],
      "defaults": {
        "local": "http://localhost:3000",
        "staging": "https://staging.fullstack.arkhamprison.com",
        "production": "https://fullstack.arkhamprison.com"
      },
      "renderSync": true
    },
    "VITE_FULLSTACK_APP_BASE_PATH": {
      "kind": "config",
      "description": "Base path for the app routing prefix",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "/app",
        "staging": "/app",
        "production": "/app"
      },
      "renderSync": true
    },
    "VITE_FULLSTACK_API_BASE_URL": {
      "kind": "config",
      "description": "Origin of the fs-ai backend API (empty when same-origin via proxy)",
      "requiredIn": ["staging", "production"],
      "defaults": {
        "local": "http://localhost:8000",
        "staging": "https://staging-api.fullstack.arkhamprison.com",
        "production": "https://api.fullstack.arkhamprison.com"
      },
      "renderSync": true
    },
    "VITE_FULLSTACK_AUTH_MODE": {
      "kind": "config",
      "description": "Auth enforcement mode: none (local dev) or external",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "none",
        "staging": "external",
        "production": "external"
      },
      "allowedValues": ["none", "external"],
      "renderSync": true
    },
    "VITE_FULLSTACK_TRUST_UPSTREAM_AUTH": {
      "kind": "config",
      "description": "Whether to trust auth headers from an upstream proxy",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "false",
        "staging": "false",
        "production": "false"
      },
      "allowedValues": ["true", "false"],
      "renderSync": true
    },
    "VITE_FULLSTACK_SESSION_PROBE_PATH": {
      "kind": "config",
      "description": "Backend path used to probe session validity",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "/api/v1/session",
        "staging": "/api/v1/session",
        "production": "/api/v1/session"
      },
      "renderSync": true
    },
    "VITE_ARKHAM_SIDECAR_ENABLED": {
      "kind": "config",
      "description": "Whether the Arkham sidecar health probe is active",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "false",
        "staging": "true",
        "production": "true"
      },
      "allowedValues": ["true", "false"],
      "renderSync": true
    },
    "VITE_ARKHAM_SIDECAR_BASE_URL": {
      "kind": "config",
      "description": "Arkham sidecar base URL",
      "requiredIn": ["staging", "production"],
      "defaults": {
        "local": "http://localhost:8100",
        "staging": "https://arkham.fullstack.arkhamprison.com",
        "production": "https://arkham.fullstack.arkhamprison.com"
      },
      "renderSync": true
    },
    "VITE_ARKHAM_SIDECAR_HEALTH_PATH": {
      "kind": "config",
      "description": "Arkham sidecar health endpoint path",
      "requiredIn": ["local", "staging", "production"],
      "defaults": {
        "local": "/health",
        "staging": "/health",
        "production": "/health"
      },
      "renderSync": true
    }
  }
}
