{
  "hosting": {
    "site": "fsai-pro",
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "/api/**",
        "run": {
          "serviceId": "fs-ai",
          "region": "us-central1"
        }
      },
      {
        "source": "/health",
        "run": {
          "serviceId": "fs-ai",
          "region": "us-central1"
        }
      },
      {
        "source": "/ready",
        "run": {
          "serviceId": "fs-ai",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  }
}
